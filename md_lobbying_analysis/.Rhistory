# Daily event count with zeroes for days with no events
session_cal <- session_2026 %>%
group_by(event_date_parsed) %>%
summarize(
num_events     = n(),
total_spending = sum(total_cost, na.rm = TRUE),
.groups = "drop"
) %>%
complete(
event_date_parsed = seq.Date(session_2026_start, session_2026_end, by = "day"),
fill = list(num_events = 0, total_spending = 0)
) %>%
mutate(
has_event   = num_events > 0,
week_of_session = ceiling(as.numeric(event_date_parsed - session_2026_start + 1) / 7)
)
write_csv(session_cal, "rstudio_output/output_session_events_by_date.csv")
# Chart: bar per event day, height = spending
p1 <- session_cal %>%
filter(has_event) %>%
ggplot(aes(x = event_date_parsed, y = total_spending)) +
geom_col(fill = "#2166ac", width = 1.5) +
scale_x_date(date_labels = "%b %d", date_breaks = "2 weeks") +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K")) +
labs(
title = "Lobbying dinners during the 2026 Maryland legislative session",
subtitle = paste0(
unique_event_dates, " event days out of ", session_days,
" days (Jan 12 – Apr 17, 2026, week-of-session window)"
),
x = NULL,
y = "Total spending per day",
caption = "Source: Maryland State Ethics Commission. Data as of April 27, 2026; final disclosures due May 31."
) +
theme_minimal(base_size = 12) +
theme(plot.subtitle = element_text(color = "gray40"))
print(p1)
ggsave("rstudio_output/viz1_session_frequency.png", p1, width = 10, height = 5, dpi = 150)
cat("Saved: rstudio_output/output_session_events_by_date.csv\n")
cat("Saved: rstudio_output/viz1_session_frequency.png\n")
View(p1)
# NOTE: When a single event invites multiple committees, the full cost is counted
# toward each committee. This is intentional — we're measuring exposure, not splitting costs.
committees_2026 <- list(
"General Assembly"     = "General Assembly",
"Senate Finance"       = "Senate Finance",
"Senate Budget & Tax"  = "Senate Budget and Taxation",
"House Appropriations" = "House Appropriations",
"House ENT"            = "Environment and Transportation",
"Senate EEE"           = "Education, Energy, and the Environment",
"House Econ Matters"   = "House Economic Matters",
"House Ways & Means"   = "House Ways and Means",
"Senate Judicial"      = "Senate Judicial Proceedings",
"House Judiciary"      = "House Judiciary"
)
cmte_spending_2026 <- map_dfr(names(committees_2026), function(label) {
pattern <- committees_2026[[label]]
matches <- session_2026 %>%
filter(str_detect(groups_invited, regex(pattern, ignore_case = TRUE)))
tibble(
committee   = label,
total_spent = sum(matches$total_cost, na.rm = TRUE),
num_events  = nrow(matches)
)
}) %>%
arrange(desc(total_spent))
write_csv(cmte_spending_2026, "rstudio_output/output_committee_spending_2026.csv")
p2 <- cmte_spending_2026 %>%
mutate(committee = fct_reorder(committee, total_spent)) %>%
ggplot(aes(x = committee, y = total_spent)) +
geom_col(fill = "#d6604d") +
geom_text(aes(label = paste0("n=", num_events)),
hjust = -0.1, size = 3.5, color = "gray30") +
coord_flip(clip = "off") +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K"),
expand = expansion(mult = c(0, 0.15))) +
labs(
title = "Lobbying dinner spending by committee, 2026 Maryland session",
subtitle = "January 14 – April 13, 2026 | n = number of events",
x = NULL,
y = "Total spending",
caption = "Source: Maryland State Ethics Commission"
) +
theme_minimal(base_size = 12) +
theme(plot.subtitle = element_text(color = "gray40"))
print(p2)
ggsave("rstudio_output/viz2_committee_spending_2026.png", p2, width = 9, height = 6, dpi = 150)
cat("Saved: rstudio_output/output_committee_spending_2026.csv\n")
cat("Saved: rstudio_output/viz2_committee_spending_2026.png\n")
# 2024-2025 full year, ENT/EEE, by utility
utility_summary_2425 <- ent_eee_2425 %>%
filter(str_detect(employer, regex(utility_pattern, ignore_case = TRUE))) %>%
mutate(utility = standardize_utility(employer)) %>%
group_by(utility) %>%
summarize(total_spent = sum(total_cost, na.rm = TRUE),
num_events  = n(), .groups = "drop") %>%
mutate(period = "2024–2025 (full year)")
# 2025-2026 session only, ENT/EEE, by utility
utility_summary_2526 <- utility_ent_eee_2026 %>%
mutate(utility = standardize_utility(employer)) %>%
group_by(utility) %>%
summarize(total_spent = sum(total_cost, na.rm = TRUE),
num_events  = n(), .groups = "drop") %>%
mutate(period = "2025–2026 (session, partial)")
utility_comparison <- bind_rows(utility_summary_2425, utility_summary_2526)
write_csv(utility_comparison, "rstudio_output/output_utility_comparison.csv")
# All utilities that appear in either period
all_utilities <- union(utility_summary_2425$utility, utility_summary_2526$utility)
# Reorder by combined total
utility_order <- utility_comparison %>%
group_by(utility) %>%
summarize(combined = sum(total_spent)) %>%
arrange(combined) %>%
pull(utility)
p3 <- utility_comparison %>%
mutate(utility = factor(utility, levels = utility_order)) %>%
ggplot(aes(x = utility, y = total_spent, fill = period)) +
geom_col(position = position_dodge(width = 0.8), width = 0.7) +
coord_flip() +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K")) +
scale_fill_manual(values = c(
"2024–2025 (full year)"       = "#74add1",
"2025–2026 (session, partial)" = "#d73027"
)) +
labs(
title = "Utility spending on ENT & EEE committee dinners",
subtitle = "Gas and electric utilities only | 2025–2026 is session-only, partial data",
x = NULL,
y = "Total spending",
fill = NULL,
caption = "Source: Maryland State Ethics Commission"
) +
theme_minimal(base_size = 12) +
theme(legend.position = "bottom",
plot.subtitle = element_text(color = "gray40"))
print(p3)
ggsave("rstudio_output/viz3_utility_comparison.png", p3, width = 9, height = 6, dpi = 150)
cat("Saved: rstudio_output/output_utility_comparison.csv\n")
cat("Saved: rstudio_output/viz3_utility_comparison.png\n")
renewable_pattern <- "solar|wind|renewable|MAREC|CHESSA|Chaberton|Advanced Energy"
top_spenders_ent_eee <- ent_eee_2026 %>%
mutate(
category = case_when(
str_detect(employer, regex(utility_pattern,   ignore_case = TRUE)) ~ "Gas/Electric Utility",
str_detect(employer, regex(renewable_pattern, ignore_case = TRUE)) ~ "Renewable Energy",
TRUE ~ "Other"
)
) %>%
group_by(employer, category) %>%
summarize(
total_spent = sum(total_cost, na.rm = TRUE),
num_events  = n(),
.groups = "drop"
) %>%
arrange(desc(total_spent)) %>%
slice_head(n = 15)
write_csv(top_spenders_ent_eee, "rstudio_output/output_top_spenders_ent_eee.csv")
p4 <- top_spenders_ent_eee %>%
# Trim long employer names for readability
mutate(
employer_label = str_trunc(employer, 45),
employer_label = fct_reorder(employer_label, total_spent)
) %>%
ggplot(aes(x = employer_label, y = total_spent, fill = category)) +
geom_col() +
geom_text(aes(label = paste0("n=", num_events)),
hjust = -0.1, size = 3, color = "gray30") +
coord_flip(clip = "off") +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K"),
expand = expansion(mult = c(0, 0.2))) +
scale_fill_manual(values = c(
"Gas/Electric Utility" = "#e08214",
"Renewable Energy"     = "#35978f",
"Other"                = "#999999"
)) +
labs(
title = "Top 15 spenders on energy committee dinners, 2026 session",
subtitle = "House ENT and/or Senate EEE | n = number of events",
x = NULL,
y = "Total spending",
fill = NULL,
caption = "Source: Maryland State Ethics Commission"
) +
theme_minimal(base_size = 12) +
theme(legend.position = "bottom",
plot.subtitle = element_text(color = "gray40"))
print(p4)
ggsave("rstudio_output/viz4_top_spenders_ent_eee.png", p4, width = 10, height = 7, dpi = 150)
cat("Saved: rstudio_output/output_top_spenders_ent_eee.csv\n")
cat("Saved: rstudio_output/viz4_top_spenders_ent_eee.png\n")
# NOTE TO PROF: This table shows side-by-side what the story says versus
# what the data shows. Empty "Data" cells mean the number wasn't in our dataset
# (e.g., historical 1999 figures came from a published annual report, not raw data).
cornerstone_note <- if (nrow(cornerstone_apr8) > 0) {
paste0("$", format(cornerstone_apr8$total_cost[1], big.mark = ",", nsmall = 2),
" — IN DATA")
} else {
"Not yet filed — check May 31 disclosures"
}
summary_df <- tibble(
`Story figure` = c(
"Year ending Oct 2025 total: $2.3 million",
"2026 session frequency: nearly every 3 days",
"Cornerstone dinner Apr 8: $9,275.11",
"Utility spending, 2026 session (all events): $172,503",
"Avg cost per event: ~$5,300",
"BGE/Pepco/WG/Constellation on ENT/EEE, 2025: ~$70,000",
"1999 receptions total: $684,958"
),
`What the data shows` = c(
paste0("$", format(total_2425$total_spending, big.mark = ",", nsmall = 2)),
paste0("Every ", round(session_days / unique_event_dates, 1), " days"),
cornerstone_note,
paste0("$", format(utility_all_total$total_spending, big.mark = ",", nsmall = 2),
" (all events) | $",
format(utility_ent_eee_total_2026$total_spending, big.mark = ",", nsmall = 2),
" (ENT/EEE only)"),
paste0("$", format(utility_all_total$avg_per_event, big.mark = ",", nsmall = 2),
" avg across utility events"),
paste0("$", format(four_utilities_total$total_spending, big.mark = ",", nsmall = 2),
" full year | $",
format(four_utilities_session_total$total_spending, big.mark = ",", nsmall = 2),
" session only"),
"From 1999 Ethics Commission annual report — not in our dataset"
)
)
