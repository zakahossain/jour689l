# Daily event count with zeroes for days with no events
session_cal <- session_2026 %>%
group_by(event_date_parsed) %>%
summarize(
num_events     = n(),
total_spending = sum(total_cost, na.rm = TRUE),
.groups = "drop"
) %>%
complete(
event_date_parsed = seq.Date(session_2026_start, session_2026_end, by = "day"),
fill = list(num_events = 0, total_spending = 0)
) %>%
mutate(
has_event   = num_events > 0,
week_of_session = ceiling(as.numeric(event_date_parsed - session_2026_start + 1) / 7)
)
write_csv(session_cal, "rstudio_output/output_session_events_by_date.csv")
p1 <- session_cal %>%
filter(has_event) %>%
ggplot(aes(x = event_date_parsed, y = total_spending)) +
geom_col(fill = "#2166ac", width = 1.5) +
scale_x_date(date_labels = "%b %d", date_breaks = "2 weeks") +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K")) +
labs(
title = "Lobbying dinners during the 2026 Maryland legislative session",
subtitle = paste0(
unique_event_dates, " event days out of ", session_days,
" days (Jan 12 – Apr 17, 2026, week-of-session window)"
),
x = NULL,
y = "Total spending per day",
caption = "Source: Maryland State Ethics Commission. Data as of April 27, 2026."
) +
theme_minimal(base_size = 12) +
theme(plot.subtitle = element_text(color = "gray40"))
print(p1)
ggsave("rstudio_output/viz1_session_frequency.png", p1, width = 10, height = 5, dpi = 150)
cat("Saved: rstudio_output/output_session_events_by_date.csv\n")
cat("Saved: rstudio_output/viz1_session_frequency.png\n")
# NOTE: When a single event invites multiple committees, the full cost is counted
# toward each committee. This is intentional — we're measuring exposure, not splitting costs.
committees_2026 <- list(
"General Assembly"     = "General Assembly",
"Senate Finance"       = "Senate Finance",
"Senate Budget & Tax"  = "Senate Budget and Taxation",
"House Appropriations" = "House Appropriations",
"House ENT"            = "Environment and Transportation",
"Senate EEE"           = "Education, Energy, and the Environment",
"House Econ Matters"   = "House Economic Matters",
"House Ways & Means"   = "House Ways and Means",
"Senate Judicial"      = "Senate Judicial Proceedings",
"House Judiciary"      = "House Judiciary"
)
cmte_spending_2026 <- map_dfr(names(committees_2026), function(label) {
pattern <- committees_2026[[label]]
matches <- session_2026 %>%
filter(str_detect(groups_invited, regex(pattern, ignore_case = TRUE)))
tibble(
committee   = label,
total_spent = sum(matches$total_cost, na.rm = TRUE),
num_events  = nrow(matches)
)
}) %>%
arrange(desc(total_spent))
write_csv(cmte_spending_2026, "rstudio_output/output_committee_spending_2026.csv")
p2 <- cmte_spending_2026 %>%
mutate(committee = fct_reorder(committee, total_spent)) %>%
ggplot(aes(x = committee, y = total_spent)) +
geom_col(fill = "#d6604d") +
geom_text(aes(label = paste0("n=", num_events)),
hjust = -0.1, size = 3.5, color = "gray30") +
coord_flip(clip = "off") +
scale_y_continuous(labels = dollar_format(scale = 1e-3, suffix = "K"),
expand = expansion(mult = c(0, 0.15))) +
labs(
title = "Lobbying dinner spending by committee, 2026 Maryland session",
subtitle = "Jan 12 – Apr 17, 2026 (week-of-session window) | n = number of events",
x = NULL,
y = "Total spending",
caption = "Source: Maryland State Ethics Commission"
) +
theme_minimal(base_size = 12) +
theme(plot.subtitle = element_text(color = "gray40"))
print(p2)
ggsave("rstudio_output/viz2_committee_spending_2026.png", p2, width = 9, height = 6, dpi = 150)
cat("Saved: rstudio_output/output_committee_spending_2026.csv\n")
cat("Saved: rstudio_output/viz2_committee_spending_2026.png\n")
